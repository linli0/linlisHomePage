# JWT — replace in production
JWT_SECRET=change-me-to-a-long-random-secret

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Feature flags (core modules always on; plugins default off)
FEATURES_AI_ENABLED=false
FEATURES_TWEETS_ENABLED=false
FEATURES_QUANT_ENABLED=false
FEATURES_XIAOMI_ENABLED=false

# Optional MySQL (leave empty to use H2 file DB in container volume)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=homepage
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=root123

# Optional integrations
METALPRICE_ENABLED=false
METALPRICE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
TWITTER_BEARER_TOKEN=
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
XIAOMI_DEVICE_IP=
XIAOMI_DEVICE_TOKEN=
