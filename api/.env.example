# Optional fallback if no web bind yet
XIAOMI_ENABLED=false
XIAOMI_DEVICE_IP=
XIAOMI_DEVICE_TOKEN=
XIAOMI_DEVICE_DID=
XIAOMI_DEVICE_NAME=客厅小爱
XIAOMI_DEVICE_MODEL=LX06
XIAOMI_TIMEOUT_SEC=10

# DeepSeek (default dialogue provider)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_DEFAULT_PROVIDER=deepseek

# Ollama fallback
OLLAMA_BASE_URL=http://localhost:11434

# Dialogue / announce
XIAOMI_DIALOGUE_IDLE_SEC=120
XIAOMI_TTS_COOLDOWN_MS=500
XIAOMI_ANNOUNCE_DEBOUNCE_SEC=30
# CURSOR_TRANSCRIPTS_DIR=
# CODEX_SESSIONS_DIR=
# REPO_ROOT=

# JWT secret also derives Fernet key for encrypted Xiaomi tokens in SQLite
# JWT_SECRET=change-me-in-production
